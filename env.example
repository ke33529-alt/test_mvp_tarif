# =============================================================================
# РЕГУЛА.AI — .env.example
# =============================================================================
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
#
# ВАЖНО: файл .env никогда не попадает в git (см. .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — Ollama (основной сервис)
# -----------------------------------------------------------------------------

# URL Ollama сервера
# Если Ollama запущен на той же машине (хост-сети):
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Если Ollama в отдельном контейнере compose (раскомментируйте):
# OLLAMA_BASE_URL=http://ollama:11434
# Если Ollama на другом сервере:
# OLLAMA_BASE_URL=http://192.168.1.100:11434

# Модель по умолчанию
OLLAMA_MODEL=qwen3:9b

# Таймаут запросов к LLM (секунды)
LLM_TIMEOUT=300

# -----------------------------------------------------------------------------
# Пути к данным (внутри контейнера — не менять если не знаете зачем)
# -----------------------------------------------------------------------------
DATA_DIR=/app/data
CONFIG_DIR=/app/config
VECTOR_DB_PATH=/app/data/vector_db
RAW_DOCS_PATH=/app/data/raw

# -----------------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# ChromaDB
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=/app/data/vector_db

# -----------------------------------------------------------------------------
# OCR настройки
# -----------------------------------------------------------------------------
# Языки для EasyOCR (через запятую)
EASYOCR_LANGUAGES=ru,en

# Использовать GPU для OCR (true/false)
EASYOCR_GPU=false

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
