# streamlit_pages/tariff_planner.py
import streamlit as st
import pandas as pd
import networkx as nx
from datetime import datetime, timedelta
import re
import json
import os

# =============================================================================
# Функции анализа зависимостей
# =============================================================================

def extract_organization_mentions(text, known_orgs):
    """Извлекает упоминания других организаций из текста заявки"""
    mentions = []
    text_lower = text.lower()
    
    for org in known_orgs:
        # Поиск по названию или ИНН
        if org['name'].lower() in text_lower or str(org['inn']) in text:
            if org['inn'] != known_orgs:  # Не считаем саму себя
                mentions.append(org['inn'])
    
    return list(set(mentions))

def build_dependency_graph(applications):
    """Строит граф зависимостей на основе упоминаний в заявках"""
    
    G = nx.DiGraph()
    
    # Добавляем узлы
    for app in applications:
        G.add_node(app['inn'], name=app['organization'], sphere=app.get('sphere', 'unknown'))
    
    # Добавляем рёбра: А упоминает Б → А зависит от Б (Б должно быть утверждено раньше)
    for app in applications:
        mentions = extract_organization_mentions(
            app.get('text', ''), 
            [a for a in applications if a['inn'] != app['inn']]
        )
        for mentioned_inn in mentions:
            if mentioned_inn in G.nodes:
                G.add_edge(app['inn'], mentioned_inn)
    
    return G

def detect_cycles(G):
    """Находит циклические зависимости"""
    try:
        cycles = list(nx.simple_cycles(G))
        return cycles
    except:
        return []

def topological_order_with_deadlines(G, applications, deadlines):
    """Топологическая сортировка с учётом дедлайнов"""
    
    # Копируем граф для модификаций
    G_copy = G.copy()
    
    # Словарь дедлайнов по ИНН
    deadline_map = {app['inn']: app.get('deadline') for app in applications}
    
    # Топологическая сортировка с приоритетом дедлайнов
    result = []
    in_degree = dict(G_copy.in_degree())
    
    # Начинаем с узлов без входящих рёбер
    available = [n for n, d in in_degree.items() if d == 0]
    
    while available:
        # Сортируем по дедлайну (раньше дедлайн → раньше в очереди)
        available.sort(key=lambda x: deadline_map.get(x) or datetime.max)
        
        # Берём первый (самый срочный)
        current = available.pop(0)
        result.append(current)
        
        # Обновляем доступные узлы
        for neighbor in G_copy.successors(current):
            in_degree[neighbor] -= 1
            if in_degree[neighbor] == 0 and neighbor not in result and neighbor not in available:
                available.append(neighbor)
    
    # Если остались узлы — есть циклы, добавляем их в конец
    remaining = [n for n in G.nodes if n not in result]
    result.extend(remaining)
    
    return result

def calculate_approval_dates(order, applications, start_date, deadlines):
    """Рассчитывает даты утверждения на основе порядка и дедлайнов"""
    
    schedule = {}
    current_date = start_date
    
    deadline_map = {app['inn']: app.get('deadline') for app in applications}
    
    for inn in order:
        app = next((a for a in applications if a['inn'] == inn), None)
        if not app:
            continue
        
        deadline = deadline_map.get(inn)
        
        # Если дедлайн уже прошёл или близко — ставим на сегодня
        if deadline and deadline < current_date + timedelta(days=3):
            schedule[inn] = deadline
        else:
            schedule[inn] = current_date
        
        # Сдвигаем дату на 1 день для следующего (можно настроить)
        current_date = schedule[inn] + timedelta(days=1)
    
    return schedule

# =============================================================================
# Визуализация графа
# =============================================================================

def visualize_dependency_graph(G, applications, schedule, cycles):
    """Создаёт визуализацию графа зависимостей"""
    
    try:
        import plotly.graph_objects as go
        
        # Layout графа
        pos = nx.spring_layout(G, k=2, iterations=50, seed=42)
        
        # Узлы
        node_x, node_y, node_text, node_color = [], [], [], []
        
        for node in G.nodes():
            x, y = pos[node]
            app = next((a for a in applications if a['inn'] == node), None)
            
            node_x.append(x)
            node_y.append(y)
            
            # Текст при наведении
            status = "⚠️ ЦИКЛ" if any(node in cycle for cycle in cycles) else "✅"
            deadline = app.get('deadline') if app else None
            dl_text = f"Дедлайн: {deadline.strftime('%d.%m.%Y')}" if deadline else "Нет дедлайна"
            approved = schedule.get(node)
            appr_text = f"План: {approved.strftime('%d.%m.%Y')}" if approved else ""
            
            node_text.append(f"{app['organization'] if app else node}<br>{status}<br>{dl_text}<br>{appr_text}")
            
            # Цвет: красный для циклов, жёлтый для дедлайнов < 7 дней, зелёный иначе
            if any(node in cycle for cycle in cycles):
                node_color.append('#ef4444')  # красный
            elif deadline and deadline < (schedule.get(node) or datetime.now()) + timedelta(days=7):
                node_color.append('#f59e0b')  # жёлтый
            else:
                node_color.append('#22c55e')  # зелёный
        
        # Рёбра
        edge_x, edge_y = [], []
        for edge in G.edges():
            x0, y0 = pos[edge[0]]
            x1, y1 = pos[edge[1]]
            edge_x.extend([x0, x1, None])
            edge_y.extend([y0, y1, None])
        
        # Создаём figure
        fig = go.Figure()
        
        # Рёбра
        fig.add_trace(go.Scatter(
            x=edge_x, y=edge_y,
            line=dict(width=1, color='#94a3b8'),
            hoverinfo='skip',
            mode='lines'
        ))
        
        # Узлы
        fig.add_trace(go.Scatter(
            x=node_x, y=node_y,
            mode='markers+text',
            marker=dict(size=20, color=node_color, line=dict(width=2, color='white')),
            text=[next((a['organization'] for a in applications if a['inn'] == n), n)[:15] + '...' for n in G.nodes()],
            textposition="bottom center",
            hovertext=node_text,
            hoverinfo='text',
            name='Организации'
        ))
        
        fig.update_layout(
            title="🔗 Граф зависимостей тарифных заявок",
            showlegend=False,
            hovermode='closest',
            margin=dict(b=20, l=5, r=5, t=40),
            xaxis=dict(showgrid=False, zeroline=False, showticklabels=False),
            yaxis=dict(showgrid=False, zeroline=False, showticklabels=False),
            plot_bgcolor='white',
            height=600
        )
        
        return fig
        
    except ImportError:
        # Fallback: текстовое представление
        st.warning("⚠️ Установите plotly для визуализации графа: pip install plotly")
        return None

# =============================================================================
# Экспорт в Excel
# =============================================================================

def export_schedule_to_excel(applications, schedule, order, cycles, G):
    """Экспортирует план в Excel"""
    
    rows = []
    for i, inn in enumerate(order, 1):
        app = next((a for a in applications if a['inn'] == inn), {})
        
        # Получаем зависимости из графа
        deps = list(G.predecessors(inn)) if G else []
        dep_names = []
        for dep_inn in deps:
            dep_app = next((a for a in applications if a['inn'] == dep_inn), {})
            dep_names.append(dep_app.get('organization', dep_inn))
        
        rows.append({
            "Порядок": i,
            "Организация": app.get('organization', inn),
            "ИНН": inn,
            "Сфера": app.get('sphere', ''),
            "Плановая дата утверждения": schedule.get(inn),
            "Дедлайн по НПА": app.get('deadline'),
            "Циклическая зависимость": "⚠️ ДА" if any(inn in c for c in cycles) else "Нет",
            "Зависит от": ", ".join(dep_names) if dep_names else "-"
        })
    
    df = pd.DataFrame(rows)
    
    # Сохранение
    output = f"tariff_schedule_{datetime.now().strftime('%Y%m%d')}.xlsx"
    df.to_excel(output, index=False)
    
    return output

# =============================================================================
# Интерфейс Streamlit
# =============================================================================

def show_tariff_planner():
    """Страница Планировщика тарифной кампании"""
    
    st.header("🗓️ Планировщик тарифной кампании")
    st.info("📌 Определяет порядок утверждения тарифов на основе взаимных зависимостей в НВВ")
    
    # Инициализация session_state
    if "applications" not in st.session_state:
        st.session_state.applications = []
    if "graph" not in st.session_state:
        st.session_state.graph = None
    if "schedule" not in st.session_state:
        st.session_state.schedule = {}
    if "order" not in st.session_state:
        st.session_state.order = []
    if "cycles" not in st.session_state:
        st.session_state.cycles = []
    
    # ─────────────────────────────────────────────────────────────────────
    # Шаг 1: Загрузка данных
    # ─────────────────────────────────────────────────────────────────────
    st.subheader("1. Загрузка заявок")
    
    # Кнопка импорта из Анализатора заявок
    if st.button("📥 Загрузить из «Анализатора заявок»", use_container_width=True):
        # Имитация загрузки (в реальности — вызов API или чтение общего хранилища)
        demo_apps = [
            {"inn": "7701234567", "organization": "ООО «ТеплоСеть»", "sphere": "heat", "text": "Затраты на электроэнергию для насосов ООО «ЭнергоСбыт» ИНН 7709876543", "deadline": datetime(2025, 6, 1)},
            {"inn": "7709876543", "organization": "ООО «ЭнергоСбыт»", "sphere": "electricity", "text": "Тариф включает услуги по передаче тепла от ООО «ТеплоСеть»", "deadline": datetime(2025, 5, 15)},
            {"inn": "7705555555", "organization": "МУП «Водоканал»", "sphere": "water", "text": "Независимая заявка без внешних зависимостей", "deadline": datetime(2025, 5, 30)},
        ]
        st.session_state.applications = demo_apps
        st.success(f"✅ Загружено {len(demo_apps)} заявок")
    
    # Ручной ввод (упрощённый)
    with st.expander("➕ Добавить заявку вручную", expanded=False):
        col1, col2, col3 = st.columns(3)
        with col1:
            new_inn = st.text_input("ИНН", key="new_inn")
        with col2:
            new_org = st.text_input("Организация", key="new_org")
        with col3:
            new_sphere = st.selectbox("Сфера", ["heat", "water", "wastewater", "tko", "electricity"], key="new_sphere")
        new_deadline = st.date_input("Дедлайн", key="new_deadline")
        new_text = st.text_area("Текст заявки (для анализа упоминаний)", key="new_text")
        
        if st.button("Добавить", key="add_app_btn"):
            if new_inn and new_org:
                st.session_state.applications.append({
                    "inn": new_inn,
                    "organization": new_org,
                    "sphere": new_sphere,
                    "text": new_text,
                    "deadline": datetime.combine(new_deadline, datetime.min.time())
                })
                st.success("✅ Заявка добавлена")
    
    # ─────────────────────────────────────────────────────────────────────
    # Шаг 2: Анализ зависимостей
    # ─────────────────────────────────────────────────────────────────────
    if st.session_state.applications:
        st.divider()
        st.subheader("2. Анализ зависимостей")
        
        if st.button("🔍 Проанализировать зависимости", use_container_width=True, key="analyze_btn"):
            with st.spinner("🔄 Строим граф зависимостей..."):
                G = build_dependency_graph(st.session_state.applications)
                cycles = detect_cycles(G)
                
                start_date = datetime.now()
                order = topological_order_with_deadlines(
                    G, 
                    st.session_state.applications, 
                    {app['inn']: app.get('deadline') for app in st.session_state.applications}
                )
                schedule = calculate_approval_dates(
                    order,
                    st.session_state.applications,
                    start_date,
                    {app['inn']: app.get('deadline') for app in st.session_state.applications}
                )
                
                st.session_state.graph = G
                st.session_state.cycles = cycles
                st.session_state.order = order
                st.session_state.schedule = schedule
                
                st.success("✅ Анализ завершён")
                st.rerun()
        
        # Отображение результатов анализа
        if st.session_state.graph:
            # Таблица порядка
            st.write("**📋 Рекомендуемый порядок утверждения:**")
            
            order_data = []
            for i, inn in enumerate(st.session_state.order, 1):
                app = next((a for a in st.session_state.applications if a['inn'] == inn), {})
                cycle_mark = "⚠️" if any(inn in c for c in st.session_state.cycles) else ""
                order_data.append({
                    "№": i,
                    "Организация": f"{cycle_mark} {app.get('organization', inn)}",
                    "ИНН": inn,
                    "Сфера": app.get('sphere', ''),
                    "Плановая дата": st.session_state.schedule.get(inn),
                    "Дедлайн": app.get('deadline')
                })
            
            order_df = pd.DataFrame(order_data)
            
            # Drag-and-drop для ручного изменения порядка
            st.dataframe(order_df, use_container_width=True, hide_index=True)
            
            st.caption("💡 Перетащите строки для изменения порядка (реализуется в v2)")
            
            # ─────────────────────────────────────────────────────────────
            # Шаг 3: Календарная сетка
            # ─────────────────────────────────────────────────────────────
            st.divider()
            st.subheader("3. Календарь утверждения")
            
            calendar_data = []
            for inn, date in st.session_state.schedule.items():
                app = next((a for a in st.session_state.applications if a['inn'] == inn), {})
                calendar_data.append({
                    "Дата": date.date(),
                    "Организация": app.get('organization', inn),
                    "Сфера": app.get('sphere', ''),
                    "Дедлайн": app.get('deadline').date() if app.get('deadline') else None
                })
            
            calendar_df = pd.DataFrame(calendar_data).sort_values("Дата")
            st.dataframe(calendar_df, use_container_width=True, hide_index=True)
            
            # ─────────────────────────────────────────────────────────────
            # Шаг 4: Визуализация графа (НОВОЕ)
            # ─────────────────────────────────────────────────────────────
            st.divider()
            st.subheader("4. 🕸️ Граф зависимостей")
            
            st.info("""
            **Как читать граф:**
            - 🟢 Зелёный узел: нет проблем, можно утверждать по плану
            - 🟡 Жёлтый узел: дедлайн близко (< 7 дней), приоритет
            - 🔴 Красный узел: ⚠️ циклическая зависимость, требует ручного решения
            - Стрелка А → Б: заявка А упоминает организацию Б → Б должно быть утверждено раньше
            """)
            
            fig = visualize_dependency_graph(
                st.session_state.graph,
                st.session_state.applications,
                st.session_state.schedule,
                st.session_state.cycles
            )
            
            if fig:
                st.plotly_chart(fig, use_container_width=True)
            else:
                # Текстовая альтернатива
                st.write("**Зависимости в текстовом виде:**")
                for inn in st.session_state.order:
                    app = next((a for a in st.session_state.applications if a['inn'] == inn), {})
                    deps = [e[1] for e in st.session_state.graph.edges(inn)]
                    dep_names = [next((a['organization'] for a in st.session_state.applications if a['inn'] == d), d) for d in deps]
                    if dep_names:
                        st.write(f"{app.get('organization', inn)} ← зависит от: {', '.join(dep_names)}")
            
            # ─────────────────────────────────────────────────────────────
            # Шаг 5: Экспорт
            # ─────────────────────────────────────────────────────────────
            st.divider()
            st.subheader("5. Экспорт")
            
            if st.button("📊 Экспортировать в Excel", use_container_width=True, key="export_btn"):
                output_path = export_schedule_to_excel(
                    st.session_state.applications,
                    st.session_state.schedule,
                    st.session_state.order,
                    st.session_state.cycles,
                    st.session_state.graph  # ← Добавлен параметр G
                )
                
                with open(output_path, "rb") as f:
                    st.download_button(
                        label="⬇️ Скачать файл",
                        data=f,
                        file_name=output_path,
                        mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                        use_container_width=True
                    )
    
    # ─────────────────────────────────────────────────────────────────────
    # Справка
    # ─────────────────────────────────────────────────────────────────────
    with st.expander("💡 Как использовать", expanded=False):
        st.write("""
**Назначение:**

Планировщик определяет оптимальный порядок утверждения тарифных заявок на основе взаимных зависимостей в НВВ организаций.

**Как работает:**

1. **Загрузите заявки** из «Анализатора заявок» или введите вручную
2. **Система анализирует текст** заявок на упоминания других организаций
3. **Строится граф зависимостей**: если заявка А упоминает организацию Б → Б должно быть утверждено раньше
4. **Топологическая сортировка** определяет порядок утверждения
5. **Циклические зависимости** подсвечиваются красным — требуют ручного решения
6. **Календарная сетка** показывает плановые даты с учётом дедлайнов по НПА
7. **Визуализация графа** помогает увидеть структуру зависимостей
8. **Экспорт в Excel** для передачи в работу

**Важно:**

- Продукт не учитывает нагрузку на сотрудников — только последовательность
- Ручное изменение порядка возможно (перетаскивание в таблице)
- При циклах система не разрывает их автоматически — только подсвечивает
- Дедлайны по НПА учитываются как жёсткие ограничения

**Технические детали:**

- Граф строится через networkx
- Визуализация через plotly (установите: pip install plotly)
- Все данные обрабатываются локально
        """)

# =============================================================================
# Запуск
# =============================================================================

if __name__ == "__main__":
    show_tariff_planner()